# Normalize line endings across OS (LF in repo, OS-native on checkout)
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# TypeScript / JavaScript / Web
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ini text eol=lf
*.env text eol=lf

# Binary — never mangle
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.db binary
*.sqlite binary
*.lock text eol=lf
